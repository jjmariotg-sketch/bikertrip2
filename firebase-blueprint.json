{
  "entities": {
    "Trip": {
      "title": "Trip",
      "description": "A motorcycle trip route and details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "days": { "type": "integer" },
        "difficulty": { "type": "string" },
        "price": { "type": "number" },
        "bookedSeats": { "type": "integer" },
        "totalSeats": { "type": "integer" },
        "location": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "duration": { "type": "string" },
        "distance": { "type": "string" },
        "bookedByUserIds": { "type": "array" }
      },
      "required": ["name", "days", "difficulty", "price", "bookedSeats", "totalSeats", "location", "image", "description"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking made by a user for a trip",
      "type": "object",
      "properties": {
        "tripId": { "type": "string" },
        "tripName": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "bookingDate": { "type": "string" },
        "status": { "type": "string" },
        "seats": { "type": "integer" },
        "priceTotal": { "type": "number" }
      },
      "required": ["tripId", "tripName", "userId", "userEmail", "userName", "bookingDate", "status", "seats", "priceTotal"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a trip written by a user",
      "type": "object",
      "properties": {
        "tripId": { "type": "string" },
        "tripName": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhotoURL": { "type": "string" },
        "ratingRoute": { "type": "integer" },
        "ratingGuide": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["tripId", "tripName", "userId", "userName", "ratingRoute", "ratingGuide", "comment", "createdAt"]
    }
  },
  "firestore": {
    "trips": {
      "schema": "Trip",
      "description": "Available motorcycle trips"
    },
    "bookings": {
      "schema": "Booking",
      "description": "User bookings for trips"
    },
    "reviews": {
      "schema": "Review",
      "description": "User reviews for motorcycle trips"
    }
  }
}
